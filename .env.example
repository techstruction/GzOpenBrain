# .env — OpenBrain Environment Configuration
# Copy this to .env and fill in your values. Never commit .env to git.

# ─── Intelligence Backend ─────────────────────────────────────────────────────
# Options: kimi | ollama
INTELLIGENCE_BACKEND=kimi

# Kimi k2.5 (Nvidia API)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://integrate.api.nvidia.com/v1
KIMI_MODEL=moonshotai/kimi-k2-5

# Ollama (local Windows server fallback)
OLLAMA_HOST=http://your-windows-server-ip:11434
OLLAMA_MODEL=qwen3:latest

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
# Your personal Telegram user ID (for receiving digests/alerts)
TELEGRAM_OWNER_CHAT_ID=your_chat_id_here

# ─── Affine (Database) ────────────────────────────────────────────────────────
AFFINE_API_URL=http://localhost:3010
AFFINE_API_TOKEN=your_affine_token_here
AFFINE_WORKSPACE_ID=your_workspace_id_here
AFFINE_ADMIN_EMAIL=your_admin_email_here
AFFINE_ADMIN_PASSWORD=your_password_here

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the OpenBrain webhook server listens on
OPENBRAIN_PORT=8765
OPENBRAIN_HOST=0.0.0.0
