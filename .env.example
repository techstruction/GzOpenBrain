# .env — OpenBrain Environment Configuration
# Copy this to .env and fill in your values. Never commit .env to git.

# ─── Intelligence Backend ─────────────────────────────────────────────────────
# Options: nvidia | ollama
INTELLIGENCE_BACKEND=nvidia

# Nvidia API — Meta Llama 3.3 70B (primary, 40 RPM free tier)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Ollama (on-prem MacBridge fallback)
OLLAMA_HOST=https://ollama-mbp.techstruction.co
OLLAMA_MODEL=llama3.1

# ─── GOBI Telegram Bot (Gz OpenBrain Inbox) ───────────────────────────────────
GOBI_BOT_TOKEN=your_gobi_bot_token_here
GOBI_WEBHOOK_SECRET=

# ─── SQLite Database ──────────────────────────────────────────────────────────
# Path to openbrain.db
# On Zo: /home/workspace/OPENBRAIN/openbrain.db
# In Docker: /app/openbrain.db
OPENBRAIN_DB_PATH=/home/workspace/OPENBRAIN/openbrain.db

# ─── Directus (Data UI) ───────────────────────────────────────────────────────
# Deployed on Zo at port 8922, public at data.techstruction.co
# Config lives in /home/workspace/directus/.env on Zo
# DIRECTUS_SECRET and DIRECTUS_ADMIN_* are set there, not here

# ─── Server ───────────────────────────────────────────────────────────────────
OPENBRAIN_PORT=8769
OPENBRAIN_HOST=0.0.0.0
